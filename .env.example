# ==============================
# Auth / JWT
# ==============================
# Secret key used to sign JWTs (hex string; use 64+ hex chars in production).
ACEBET_SECRET_KEY=replace_with_long_random_hex
# JWT signing algorithm (e.g., HS256).
ACEBET_JWT_ALGORITHM=HS256
# Access token lifetime in minutes (integer).
ACEBET_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================
# Demo user
# ==============================
# Demo account username used for local testing.
ACEBET_DEMO_USERNAME=replace_with_demo_username
# Demo account password used for local testing.
ACEBET_DEMO_PASSWORD=replace_with_demo_password

# ==============================
# App runtime
# ==============================
# Application environment name (e.g., development, staging, production).
ACEBET_ENV=development
# Logging verbosity level (e.g., DEBUG, INFO, WARNING, ERROR).
ACEBET_LOG_LEVEL=INFO

# Default global request rate limit.
ACEBET_DEFAULT_RATE_LIMIT=60/minute
# Rate limit for the /limit endpoint demo.
ACEBET_LOGIN_RATE_LIMIT=10/minute
# Log output file path.
ACEBET_LOG_FILE=acebet.log
